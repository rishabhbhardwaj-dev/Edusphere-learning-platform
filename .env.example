# ================================================
# EdTech Platform — Root Environment Variables
# ================================================
# Copy this file as .env in each service folder
# See individual .env.example files in:
#   - server/.env.example
#   - ai-service/.env.example

# ============ SERVER ============
PORT=4000
FRONTEND_URL=http://localhost:5173
MONGODB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/edtech
JWT_SECRET=your_jwt_secret_key_here

# Cloudinary
CLOUD_NAME=your_cloudinary_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret
FOLDER_NAME=EdTechPlatform

# Razorpay
RAZORPAY_KEY=rzp_test_xxxxxxxxxxxx
RAZORPAY_SECRET=your_razorpay_secret

# Email (Gmail)
MAIL_HOST=smtp.gmail.com
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password

# AI Service URL
AI_SERVICE_URL=http://localhost:8000

# ============ FRONTEND (.env in client/) ============
# VITE_RAZORPAY_KEY=rzp_test_xxxxxxxxxxxx

# ============ AI SERVICE ============
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-api-key
# GEMINI_API_KEY=your-gemini-api-key
# TAVILY_API_KEY=tvly-your-tavily-api-key
